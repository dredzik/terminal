{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "black":     "#14191e",
    "red":       "#b5001e",
    "green":     "#169302",
    "yellow":    "#b5b200",
    "blue":      "#0059ba",
    "magenta":   "#a500b5",
    "cyan":      "#0078b5",
    "white":     "#faebd7",
    "brBlack":   "#676767",
    "brRed":     "#ff6b6b",
    "brGreen":   "#6bffc8",
    "brYellow":  "#fff26b",
    "brBlue":    "#6bb2ff",
    "brMagenta": "#f76bff",
    "brCyan":    "#6bd5ff",
    "brWhite":   "#e5e5e5"
  },
  "theme": {
    "primary":           { "dark": "brBlue",    "light": "blue"     },
    "secondary":         { "dark": "brCyan",    "light": "cyan"     },
    "accent":            { "dark": "brMagenta", "light": "magenta"  },
    "error":             { "dark": "brRed",     "light": "red"      },
    "warning":           { "dark": "brYellow",  "light": "yellow"   },
    "success":           { "dark": "brGreen",   "light": "green"    },
    "info":              { "dark": "brCyan",    "light": "cyan"     },
    "text":              { "dark": "white",     "light": "black"    },
    "textMuted":         { "dark": "brBlack",   "light": "brBlack"  },
    "background":        { "dark": "black",     "light": "black"  },
    "backgroundPanel":   { "dark": "black",     "light": "black"  },
    "backgroundElement": { "dark": "black",     "light": "black"  },
    "border":            { "dark": "brBlack",   "light": "brBlack"  },
    "borderActive":      { "dark": "brBlue",    "light": "blue"     },
    "borderSubtle":      { "dark": "brBlack",   "light": "brBlack"  },
    "diffAdded":               { "dark": "brGreen",   "light": "green"   },
    "diffRemoved":             { "dark": "brRed",     "light": "red"     },
    "diffContext":             { "dark": "brBlack",   "light": "brBlack" },
    "diffHunkHeader":          { "dark": "brCyan",    "light": "cyan"    },
    "diffHighlightAdded":      { "dark": "brGreen",   "light": "green"   },
    "diffHighlightRemoved":    { "dark": "brRed",     "light": "red"     },
    "diffAddedBg":             { "dark": "black",     "light": "brWhite" },
    "diffRemovedBg":           { "dark": "black",     "light": "brWhite" },
    "diffContextBg":           { "dark": "black",     "light": "brWhite" },
    "diffLineNumber":          { "dark": "brBlack",   "light": "brBlack" },
    "diffAddedLineNumberBg":   { "dark": "black",     "light": "brWhite" },
    "diffRemovedLineNumberBg": { "dark": "black",     "light": "brWhite" },
    "markdownText":            { "dark": "white",     "light": "black"    },
    "markdownHeading":         { "dark": "brBlue",    "light": "blue"     },
    "markdownLink":            { "dark": "brCyan",    "light": "cyan"     },
    "markdownLinkText":        { "dark": "brBlue",    "light": "blue"     },
    "markdownCode":            { "dark": "brGreen",   "light": "green"    },
    "markdownCodeBlock":       { "dark": "white",     "light": "black"    },
    "markdownBlockQuote":      { "dark": "brBlack",   "light": "brBlack"  },
    "markdownEmph":            { "dark": "brYellow",  "light": "yellow"   },
    "markdownStrong":          { "dark": "brMagenta", "light": "magenta"  },
    "markdownHorizontalRule":  { "dark": "brBlack",   "light": "brBlack"  },
    "markdownListItem":        { "dark": "brBlue",    "light": "blue"     },
    "markdownListEnumeration": { "dark": "brCyan",    "light": "cyan"     },
    "markdownImage":           { "dark": "brCyan",    "light": "cyan"     },
    "markdownImageText":       { "dark": "brBlue",    "light": "blue"     },
    "syntaxComment":     { "dark": "brBlack",   "light": "brBlack"  },
    "syntaxKeyword":     { "dark": "brMagenta", "light": "magenta"  },
    "syntaxFunction":    { "dark": "brBlue",    "light": "blue"     },
    "syntaxVariable":    { "dark": "white",     "light": "black"    },
    "syntaxString":      { "dark": "brGreen",   "light": "green"    },
    "syntaxNumber":      { "dark": "brYellow",  "light": "yellow"   },
    "syntaxType":        { "dark": "brCyan",    "light": "cyan"     },
    "syntaxOperator":    { "dark": "brBlue",    "light": "blue"     },
    "syntaxPunctuation": { "dark": "white",     "light": "black"    }
  }
}
